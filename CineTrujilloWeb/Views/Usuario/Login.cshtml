@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Login Cine Trujillo</title>
    <link rel="icon" type="image/png" href="~/img/favicon.png" />

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #f2f2f2;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .card {
            background: #fff;
            padding: 40px;
            width: 350px;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            text-align: center;
        }

        h2 {
            margin-bottom: 10px;
        }

        h3 {
            margin-top: 20px;
            margin-bottom: 5px;
            color: #555;
            font-size: 15px;
        }

        p {
            color: #777;
            font-size: 14px;
        }

        .input-group {
            position: relative;
            margin: 25px 0;
            text-align: left;
        }

            .input-group input {
                width: 100%;
                border: none;
                border-bottom: 2px solid #ccc;
                padding: 10px 5px;
                outline: none;
                font-size: 14px;
            }

            .input-group label {
                position: absolute;
                top: 10px;
                left: 5px;
                color: #999;
                font-size: 14px;
                transition: 0.3s;
            }

            .input-group input:focus {
                border-bottom: 2px solid #4a7cff;
            }

                .input-group input:focus + label,
                .input-group input:valid + label {
                    top: -10px;
                    font-size: 12px;
                    color: #4a7cff;
                }

        .show-password {
            text-align: left;
            font-size: 13px;
            color: #555;
        }

        button {
            width: 100%;
            padding: 12px;
            margin-top: 20px;
            background: #4a7cff;
            border: none;
            color: white;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
        }

            button:hover {
                background: #3a6be0;
            }

        .error {
            color: red;
            margin-top: 10px;
        }

        .logo {
            margin-bottom: 15px;
        }

            .logo img {
                width: 90px;
                height: auto;
            }

        .register {
            margin-top: 15px;
            font-size: 14px;
            color: #555;
        }

            .register a {
                color: #4a7cff;
                text-decoration: none;
                font-weight: bold;
            }

                .register a:hover {
                    text-decoration: underline;
                }
    </style>
</head>
<body>

    <div class="card">

        <div class="logo">
            <img src="~/img/logo.png" alt="Logo">
        </div>

        <h3>ACCESO</h3>
        <p>Inicia sesión para acceder a tu cuenta</p>

        @using (Html.BeginForm("Login", "Usuario", FormMethod.Post))
        {
            <div class="input-group">
                @Html.TextBox("Correo", null, new { required = "required" })
                <label>Email</label>
            </div>

            <div class="input-group">
                @Html.Password("Password", null, new { id = "password", required = "required" })
                <label>Contraseña</label>
            </div>

            <div class="show-password">
                <input type="checkbox" onclick="togglePassword()"> Mostrar contraseña
            </div>

            <button type="submit">INGRESAR</button>
        }

        <p class="error">@ViewBag.Error</p>

        <div class="register">
            <p>¿No tienes cuenta? <a href="/Usuario/Register">Regístrate</a>
        </div>

    </div>

    <script>
        function togglePassword() {
            var pass = document.getElementById("password");
            pass.type = pass.type === "password" ? "text" : "password";
        }
    </script>

</body>
</html>